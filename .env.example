# ==============================================================================
# TradingCat .env template
# Copy to .env and fill in values. .env is gitignored.
# ==============================================================================

# ----- Core app skeleton -----
TRADINGCAT_PORTFOLIO_VALUE=1000000
TRADINGCAT_BASE_CURRENCY=CNY
TRADINGCAT_DATA_DIR=data
TRADINGCAT_SMOKE_SYMBOLS=
TRADINGCAT_RELOAD=false

# ----- Persistence -----
TRADINGCAT_POSTGRES_ENABLED=false
TRADINGCAT_POSTGRES_DSN=postgresql:///tradingcat
TRADINGCAT_DUCKDB_ENABLED=false
TRADINGCAT_DUCKDB_PATH=data/research.duckdb
TRADINGCAT_PARQUET_DIR=data/parquet

# ----- Scheduler -----
TRADINGCAT_SCHEDULER_BACKEND=apscheduler
TRADINGCAT_SCHEDULER_AUTOSTART=true

# ----- Futu / OpenD (broker) -----
TRADINGCAT_FUTU_ENABLED=false
TRADINGCAT_FUTU_HOST=127.0.0.1
TRADINGCAT_FUTU_PORT=11111
TRADINGCAT_FUTU_ENVIRONMENT=SIMULATE
TRADINGCAT_FUTU_HK_TRADE_MARKET=HK
TRADINGCAT_FUTU_US_TRADE_MARKET=US
TRADINGCAT_FUTU_UNLOCK_TRADE_PASSWORD=

# ----- Market data fallback -----
TRADINGCAT_YFINANCE_ENABLED=true

# ==============================================================================
# Absorbed capabilities — TradingAgents-CN integration (Rounds 01-15)
# All off by default. Enable selectively as you wire optional deps + keys.
# See docs/ABSORB_CAPABILITIES.md for the full cookbook.
# ==============================================================================

# ----- A-share market data adapters (Rounds 01-04) -----
# Optional deps: pip install 'tradingcat[sentiment_akshare]' / [sentiment_baostock] / [sentiment_tushare]
TRADINGCAT_AKSHARE_ENABLED=false
TRADINGCAT_AKSHARE_ADJUST=qfq
TRADINGCAT_AKSHARE_SPOT_CACHE_TTL_SECONDS=30.0
TRADINGCAT_BAOSTOCK_ENABLED=false
TRADINGCAT_BAOSTOCK_ADJUSTFLAG=2
TRADINGCAT_TUSHARE_ENABLED=false
TRADINGCAT_TUSHARE_TOKEN=
TRADINGCAT_TUSHARE_ADJ=qfq

# ----- News sources (Rounds 05-06) -----
TRADINGCAT_EASTMONEY_NEWS_ENABLED=false
TRADINGCAT_EASTMONEY_NEWS_COLUMN=351
TRADINGCAT_EASTMONEY_NEWS_PAGE_SIZE=20
TRADINGCAT_EASTMONEY_NEWS_CACHE_TTL_SECONDS=600
TRADINGCAT_CLS_NEWS_ENABLED=false
TRADINGCAT_CLS_NEWS_PAGE_SIZE=20
TRADINGCAT_FINNHUB_NEWS_ENABLED=false
TRADINGCAT_FINNHUB_TOKEN=
TRADINGCAT_FINNHUB_NEWS_SYMBOLS=
TRADINGCAT_ALPHA_VANTAGE_NEWS_ENABLED=false
TRADINGCAT_ALPHA_VANTAGE_API_KEY=
TRADINGCAT_ALPHA_VANTAGE_NEWS_TICKERS=

# ----- LLM advisory layer (Rounds 11-15) -----
# Configures DeepSeek by default; swap base_url + model for Qwen / OpenAI / etc.
TRADINGCAT_LLM_ENABLED=false
TRADINGCAT_LLM_PROVIDER=deepseek
TRADINGCAT_LLM_MODEL=deepseek-chat
TRADINGCAT_LLM_BASE_URL=https://api.deepseek.com/v1
TRADINGCAT_LLM_API_KEY=
TRADINGCAT_LLM_DAILY_TOKEN_BUDGET=50000
TRADINGCAT_LLM_MONTHLY_COST_BUDGET=10.0
TRADINGCAT_LLM_COST_PER_1K_TOKENS=0.001

# ----- Daily advisory report scheduler (post-R15) -----
TRADINGCAT_ADVISORY_REPORT_ENABLED=false
TRADINGCAT_ADVISORY_REPORT_CRON_HOUR=7
TRADINGCAT_ADVISORY_REPORT_CRON_MINUTE=45
TRADINGCAT_ADVISORY_REPORT_CRON_TIMEZONE=Asia/Shanghai
TRADINGCAT_ADVISORY_REPORT_RETENTION_DAYS=30
TRADINGCAT_ADVISORY_REPORT_CANDIDATE_LIMIT=10
