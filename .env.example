# ─── TradingCat V1 Configuration ────────────────────────────────
# Copy to .env and adjust values for your environment.
# All variables have safe defaults; only uncomment what you need.

# ── Core ────────────────────────────────────────────────────────
TRADINGCAT_PORTFOLIO_VALUE=1000000       # Starting portfolio NAV (CNY)
TRADINGCAT_BASE_CURRENCY=CNY             # Base reporting currency
TRADINGCAT_DATA_DIR=data                 # Local JSON persistence directory
TRADINGCAT_SMOKE_SYMBOLS=                # Comma-separated symbols for smoke tests
TRADINGCAT_RELOAD=false                  # Enable uvicorn auto-reload (dev only)
TRADINGCAT_SEED_DEMO_DATA=false          # Auto-generate demo portfolio on startup
TRADINGCAT_APPROVAL_EXPIRY_MINUTES=60    # A-share approval request TTL
TRADINGCAT_MANUAL_ORDER_REQUIRES_APPROVAL=true

# ── Security ────────────────────────────────────────────────────
# Set a strong random key to require API authentication.
# Leave empty for localhost-only trust mode (no auth).
TRADINGCAT_API_KEY=

# ── Futu / OpenD ────────────────────────────────────────────────
TRADINGCAT_FUTU_ENABLED=false            # Enable Futu broker adapter
TRADINGCAT_FUTU_HOST=127.0.0.1           # OpenD host (use host.docker.internal in Docker)
TRADINGCAT_FUTU_PORT=11111               # OpenD port
TRADINGCAT_FUTU_ENVIRONMENT=SIMULATE     # SIMULATE or REAL
TRADINGCAT_FUTU_HK_TRADE_MARKET=HK
TRADINGCAT_FUTU_US_TRADE_MARKET=US
TRADINGCAT_FUTU_UNLOCK_TRADE_PASSWORD=   # Futu trade unlock password (if required)
TRADINGCAT_FUTU_ADAPTER_INIT_TIMEOUT_SECONDS=3.0

# ── Yahoo Finance (fallback market data) ────────────────────────
TRADINGCAT_YFINANCE_ENABLED=false

# ── PostgreSQL (optional audit/state backend) ───────────────────
TRADINGCAT_POSTGRES_ENABLED=false
TRADINGCAT_POSTGRES_DSN=postgresql:///tradingcat
# TRADINGCAT_POSTGRES_PASSWORD=           # Used by docker-compose for DB init

# ── DuckDB (optional research/analytics) ────────────────────────
TRADINGCAT_DUCKDB_ENABLED=false
TRADINGCAT_DUCKDB_PATH=data/research.duckdb
TRADINGCAT_PARQUET_DIR=data/parquet

# ── Scheduler ───────────────────────────────────────────────────
TRADINGCAT_SCHEDULER_BACKEND=apscheduler  # apscheduler or lightweight
TRADINGCAT_SCHEDULER_AUTOSTART=true

# ── Alpha Radar & Demo ──────────────────────────────────────────
TRADINGCAT_ALPHA_RADAR_SYMBOLS=SPY,QQQ,NVDA,TSLA,AAPL,MSFT,AMD
TRADINGCAT_DEMO_HISTORY_DAYS=90

# ── Macro Calendar ──────────────────────────────────────────────
# Override with a custom JSON calendar endpoint (optional).
# Default: Nager.Date US public holidays + built-in recurring events.
# TRADINGCAT_MACRO_CALENDAR_URL=
