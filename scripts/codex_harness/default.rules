prefix_rule(
    pattern = ["git", "reset", "--hard"],
    decision = "forbidden",
    justification = "Discarding worktree changes is destructive. Inspect the diff or switch branches instead.",
    match = [
        "git reset --hard",
    ],
    not_match = [
        "git reset --soft HEAD~1",
    ],
)

prefix_rule(
    pattern = ["git", "clean", ["-f", "--force", "-fd", "-df", "-fxd", "-xfd"]],
    decision = "forbidden",
    justification = "Forced git clean deletes untracked files. Use `git clean -n` to preview first.",
    match = [
        "git clean -f",
        "git clean -fd",
    ],
    not_match = [
        "git clean -n",
    ],
)

prefix_rule(
    pattern = ["diskutil", "eraseDisk"],
    decision = "forbidden",
    justification = "Disk erase operations are destructive and should never run from Codex.",
    match = [
        "diskutil eraseDisk APFS Scratch /dev/disk4",
    ],
    not_match = [
        "diskutil list",
    ],
)

prefix_rule(
    pattern = [["mkfs", "mkfs.ext4", "mkfs.exfat", "mkfs.fat", "newfs", "newfs_hfs"]],
    decision = "forbidden",
    justification = "Filesystem formatting commands are destructive and should never run from Codex.",
    match = [
        "mkfs.ext4 /dev/sdb1",
        "newfs_hfs /dev/disk4s1",
    ],
    not_match = [
        "echo mkfs.ext4 /dev/sdb1",
    ],
)

prefix_rule(
    pattern = [["shutdown", "reboot", "halt", "poweroff"]],
    decision = "forbidden",
    justification = "System power commands interrupt the workstation and are never appropriate for Codex.",
    match = [
        "shutdown -r now",
        "reboot",
    ],
    not_match = [
        "echo reboot",
    ],
)

prefix_rule(
    pattern = ["sudo"],
    decision = "prompt",
    justification = "Privilege escalation is sensitive. Confirm the exact command before allowing it.",
    match = [
        "sudo ls /var/root",
    ],
    not_match = [
        "ls /var/root",
    ],
)

prefix_rule(
    pattern = ["git", "branch", "-D"],
    decision = "prompt",
    justification = "Force-deleting a branch can remove recovery points. Confirm before proceeding.",
    match = [
        "git branch -D old-work",
    ],
    not_match = [
        "git branch -d old-work",
    ],
)

prefix_rule(
    pattern = ["killall"],
    decision = "prompt",
    justification = "Bulk process termination is high impact. Confirm the target process first.",
    match = [
        "killall python3",
    ],
    not_match = [
        "kill -9 1234",
    ],
)

prefix_rule(
    pattern = ["pkill", "-9"],
    decision = "prompt",
    justification = "Forced bulk process termination is high impact. Confirm before allowing it.",
    match = [
        "pkill -9 node",
    ],
    not_match = [
        "pkill node",
    ],
)
